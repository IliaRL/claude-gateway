# Prevent semgrep from scanning vendor/generated directories.
# Without this, securecoder/Aikido spawns 37-171 concurrent semgrep-core-proprietary
# processes (57GB virtual) trying to scan 187MB of node_modules, causing kernel panics.
node_modules/
logs/
*.log
dist/
build/
coverage/
.pnpm-store/
pnpm-lock.yaml
*.lock
scripts/omni-test.cjs
scripts/master-smoke-test.cjs
